---
import '../styles/global.css';

const {
  title = '元物质 | 科研智算能力建设公司',
  description = '元物质面向高校课题组和科研组织，提供元小鲲科研智算一体机、元Space 和科研智算能力建设服务'
} = Astro.props;

const navItems = [
  { href: '/', label: '首页' },
  {
    href: '/scenarios/',
    label: '科研场景',
    children: [
      { href: '/scenarios/school-computing-center/', label: '学校智算中心建设' },
      { href: '/scenarios/college-research-platform/', label: '院系科研算力平台' },
      { href: '/scenarios/research-group-computing-center/', label: '课题组小型智算中心' },
      { href: '/scenarios/', label: '实验室 AI 科研算力' }
    ]
  },
  {
    href: '/products/',
    label: '产品与能力',
    children: [
      { href: '/xiaokun/', label: '元小鲲科研智算一体机' },
      { href: '/yuanspace/', label: '元Space 科研智算平台' },
      {
        href: '/products/',
        label: '工程能力与其他产品',
        children: [
          { href: '/products/', label: '元Meta' },
          { href: '/products/', label: '元Power' },
          { href: '/products/', label: '元Data' },
          { href: '/products/', label: '元Link' },
          { href: '/products/', label: '元Base' },
          { href: '/products/', label: '元Safe' },
          { href: '/products/', label: '交付与运维服务' }
        ]
      }
    ]
  },
  {
    href: '/cases/',
    label: '客户实践',
    children: [
      { href: '/cases/', label: '典型需求场景' },
      { href: '/cases/', label: '高校与科研机构' },
      { href: '/cases/', label: '案例持续更新' }
    ]
  },
  {
    href: '/research-computing/',
    label: '科研智算',
    children: [
      { href: '/research-computing/', label: '什么是科研智算' },
      { href: '/research-computing/', label: '科研算网' },
      { href: '/research-computing/', label: '科研工作流' },
      { href: '/faq/', label: 'FAQ' }
    ]
  },
  {
    href: '/resources/',
    label: '动态与资源',
    children: [
      { href: '/resources/', label: '新闻活动' },
      { href: '/resources/', label: '媒体报道' },
      { href: '/resources/', label: '文档中心' }
    ]
  },
  {
    href: '/support/',
    label: '技术支持',
    children: [
      { href: '/support/', label: '产品查询入口' }
    ]
  },
  {
    href: '/about/',
    label: '关于元物质',
    children: [
      { href: '/about/', label: '公司介绍' },
      { href: '/about/', label: '加入我们' },
      { href: '/contact/', label: '联系我们' }
    ]
  }
];
---
<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <link rel="icon" href="/assets/yuanwuzhi-logo-transparent-blue.png" />
  </head>
  <body>
    <header class="site-header">
      <nav class="nav" aria-label="主导航">
        <a class="brand-link" href="/">
          <img class="brand-logo" src="/assets/yuanwuzhi-logo-transparent-blue.png" alt="元物质" />
        </a>
        <div class="nav-links">
          {navItems.map((item) => (
            <div class:list={['nav-item', item.children && 'has-menu']}>
              <a class="nav-link" href={item.href}>{item.label}</a>
              {item.children && (
                <div class="nav-menu">
                  <div class="nav-menu-panel">
                    {item.children.map((child) => (
                      <div class:list={['nav-menu-row', child.children && 'has-children']}>
                        <a href={child.href}>
                          <span>{child.label}</span>
                          {child.children && <b>›</b>}
                        </a>
                        {child.children && (
                          <div class="nav-submenu">
                            {child.children.map((grandchild) => (
                              <a href={grandchild.href}>{grandchild.label}</a>
                            ))}
                          </div>
                        )}
                      </div>
                    ))}
                  </div>
                </div>
              )}
            </div>
          ))}
          <a class="nav-ghost" href="/resources/">文档中心</a>
          <a class="nav-cta" href="/contact/">联系咨询</a>
        </div>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <div class="footer-inner">
        <div class="footer-brand">
          <img src="/assets/yuanwuzhi-logo-transparent-blue.png" alt="元物质" />
          <p>面向高校课题组、实验室和科研组织的科研智算能力建设伙伴，让科研智算像水电一样简单</p>
          <a class="footer-cta" href="/contact/">联系咨询</a>
        </div>
        <div class="footer-column">
          <h3>科研场景</h3>
          <a href="/scenarios/school-computing-center/">学校智算中心建设</a>
          <a href="/scenarios/college-research-platform/">院系科研算力平台</a>
          <a href="/scenarios/research-group-computing-center/">课题组小型智算中心</a>
          <a href="/scenarios/">实验室 AI 科研算力</a>
        </div>
        <div class="footer-column">
          <h3>产品与能力</h3>
          <a href="/xiaokun/">元小鲲科研智算一体机</a>
          <a href="/yuanspace/">元Space 科研智算平台</a>
          <a href="/products/">工程能力与其他产品</a>
          <a href="/support/">技术支持</a>
        </div>
        <div class="footer-column">
          <h3>资源与公司</h3>
          <a href="/cases/">客户实践</a>
          <a href="/research-computing/">科研智算</a>
          <a href="/resources/">动态与资源</a>
          <a href="/about/">关于元物质</a>
        </div>
        <div class="footer-contact">
          <h3>联系元物质</h3>
          <p>科研智算咨询、产品沟通、项目线索与技术支持</p>
          <a href="/contact/">提交咨询需求</a>
          <a href="/support/">产品信息查询</a>
        </div>
      </div>
      <div class="footer-bottom">
        <span>© 2026 元物质 All rights reserved</span>
        <div>
          <a href="/faq/">FAQ</a>
          <a href="/contact/">联系我们</a>
        </div>
      </div>
    </footer>
  </body>
</html>
