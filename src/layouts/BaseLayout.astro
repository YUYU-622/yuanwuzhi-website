---
import '../styles/global.css';

const {
  title = '元物质 | 科研智算能力建设公司',
  description = '元物质面向高校课题组和科研组织，提供元小鲲科研智算一体机、元Space 和科研智算能力建设服务'
} = Astro.props;

const navItems = [
  { href: '/', label: '首页' },
  { href: '/scenarios/', label: '科研场景' },
  { href: '/products/', label: '产品与能力' },
  { href: '/cases/', label: '客户实践' },
  { href: '/research-computing/', label: '科研智算' },
  { href: '/resources/', label: '动态与资源' },
  { href: '/support/', label: '技术支持' },
  { href: '/about/', label: '关于元物质' }
];
---
<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <link rel="icon" href="/assets/yuanwuzhi-logo-transparent-blue.png" />
  </head>
  <body>
    <header class="site-header">
      <nav class="nav" aria-label="主导航">
        <a class="brand-link" href="/">
          <img class="brand-logo" src="/assets/yuanwuzhi-logo-transparent-blue.png" alt="元物质" />
        </a>
        <div class="nav-links">
          {navItems.map((item) => <a href={item.href}>{item.label}</a>)}
          <a class="nav-ghost" href="/resources/">文档中心</a>
          <a class="nav-cta" href="/contact/">联系咨询</a>
        </div>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <div class="footer-inner">
        <div class="footer-brand">
          <img src="/assets/yuanwuzhi-logo-transparent-blue.png" alt="元物质" />
          <p>面向高校课题组、实验室和科研组织的科研智算能力建设伙伴，让科研智算像水电一样简单</p>
          <a class="footer-cta" href="/contact/">联系咨询</a>
        </div>
        <div class="footer-column">
          <h3>科研场景</h3>
          <a href="/scenarios/">学校智算中心建设</a>
          <a href="/scenarios/">院系科研算力平台</a>
          <a href="/scenarios/">课题组小型智算中心</a>
          <a href="/scenarios/">实验室 AI 科研算力</a>
        </div>
        <div class="footer-column">
          <h3>产品与能力</h3>
          <a href="/xiaokun/">元小鲲科研智算一体机</a>
          <a href="/yuanspace/">元Space 科研智算平台</a>
          <a href="/products/">工程能力与其他产品</a>
          <a href="/support/">技术支持</a>
        </div>
        <div class="footer-column">
          <h3>资源与公司</h3>
          <a href="/cases/">客户实践</a>
          <a href="/research-computing/">科研智算</a>
          <a href="/resources/">动态与资源</a>
          <a href="/about/">关于元物质</a>
        </div>
        <div class="footer-contact">
          <h3>联系元物质</h3>
          <p>科研智算咨询、产品沟通、项目线索与技术支持</p>
          <a href="/contact/">提交咨询需求</a>
          <a href="/support/">产品信息查询</a>
        </div>
      </div>
      <div class="footer-bottom">
        <span>© 2026 元物质 All rights reserved</span>
        <div>
          <a href="/faq/">FAQ</a>
          <a href="/contact/">联系我们</a>
        </div>
      </div>
    </footer>
  </body>
</html>
