---
import BaseLayout from '../layouts/BaseLayout.astro';

const faqs = [
  ['元小鲲科研智算一体机是什么？', '元小鲲科研智算一体机是元物质面向高校课题组和科研团队推出的软硬一体科研智算工具，帮助课题组更低门槛地启动本地 AI 科研环境。'],
  ['元小鲲和普通 GPU 服务器有什么区别？', '普通 GPU 服务器更强调算力参数和机房部署。元小鲲更关注课题组真实使用场景，包括实验室部署、低噪音、散热、上手门槛、资源可视和服务支持。'],
  ['为什么元小鲲适合放在实验室？', '元小鲲采用浸没式液冷形态，关注噪音、散热、状态可见性和空间部署体验，让算力设备更接近科研现场。'],
  ['浸没式液冷有什么价值？', '浸没式液冷可以降低传统高性能设备的噪音压力，改善高负载散热体验，并形成更强的视觉识别和状态感知。'],
  ['元Space 在元小鲲一体机里做什么？', '元Space 主要承担用户和权限管理、资源可视化、科研环境基础支撑、设备状态和资源使用情况可见性等基础能力。'],
  ['元小鲲是否支持根据预算和配置定制？', '可以根据课题组预算、科研任务和部署条件进行方案评估，形成适合具体团队的配置与服务方案。'],
  ['元小鲲能替代学校智算中心或云算力吗？', '不建议这样理解。元小鲲更适合作为课题组身边的本地科研智算工具，解决日常高频、需要自主掌控、需要快速启动的科研任务。'],
  ['哪些内容需要以最终方案为准？', '具体配置、服务范围、部署条件、扩展方式和长期运维方案，需要结合最终产品版本与课题组实际需求确认。']
];
---
<BaseLayout
  title="FAQ | 元小鲲科研智算一体机"
  description="关于元小鲲科研智算一体机、浸没式液冷、元Space 和课题组本地 AI 科研算力的常见问题。"
>
  <section class="page-title">
    <div class="section-inner">
      <div class="eyebrow">FAQ</div>
      <h1>关于元小鲲，你可能会先问这些问题。</h1>
      <p>围绕元小鲲、浸没式液冷、元Space 和课题组本地 AI 科研算力，回答常见问题。</p>
    </div>
  </section>

  <section class="page-section">
    <div class="section-inner faq-list">
      {faqs.map(([question, answer]) => (
        <article class="faq-item">
          <h3>{question}</h3>
          <p>{answer}</p>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
